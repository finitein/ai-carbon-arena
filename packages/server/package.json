{
  "name": "@carbon-arena/server",
  "version": "0.1.0",
  "private": true,
  "description": "Carbon-Silicon Arena Backend Server (Fastify + WebSocket)",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/app.ts",
    "start": "node dist/app.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@carbon-arena/engine": "workspace:*",
    "@carbon-arena/protocol": "workspace:*",
    "@fastify/cors": "^9.0.0",
    "@fastify/websocket": "^9.0.0",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.30.0",
    "fastify": "^4.26.0",
    "ioredis": "^5.3.0",
    "jsonwebtoken": "^9.0.3",
    "postgres": "^3.4.0",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.5.0",
    "drizzle-kit": "^0.21.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  }
}
